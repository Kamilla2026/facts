import tkinter as tk
import random

git_hub = "https://github.com/Kamilla2026/facts"

facts = [
 "Бананы радиоактивны и излучают небольшое количество гамма-излучения.",
 "Человек может обойтись без пищи до 2 месяцев, а без воды — всего несколько дней.",
 "Голубые киты ежедневно потребляют около 4 тонн пищи.",
 "Пчёлы могут распознавать лица людей.",
 "Существует 6 000 видов бананов, а не только один."

 ]

def show_random_fact():
    random_fact = random.choice(facts)
    label.config(text=random_fact)

window = tk.Tk()
window.title("Интересные факты")
window.geometry("400x200")

label = tk.Label(window, text="", font=("Arial", 12), wraplength=350, justify="center")
label.pack(pady=20)

button = tk.Button(window, text="Показать факт", font=("Arial", 10), command=show_random_fact)
button.pack(pady=10)

window.mainloop()
